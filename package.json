{
  "name": "sujeet-pro.github.io",
  "version": "1.0.0",
  "description": "Open source projects and tools by Sujeet Jaiswal.",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sujeet-pro/sujeet-pro.github.io.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "lint": "vp lint",
    "format": "vp fmt . --write",
    "format:check": "vp fmt --check",
    "check": "vp check",
    "validate": "node --experimental-strip-types --no-warnings scripts/validate.ts",
    "validate:content": "node --experimental-strip-types --no-warnings scripts/validate.ts --content",
    "validate:build": "node --experimental-strip-types --no-warnings scripts/validate.ts --build",
    "test": "vp test",
    "test:watch": "vp test watch",
    "typecheck": "tsc --noEmit",
    "check:ci": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build && npm run validate",
    "render:diagrams": "diagramkit render content/",
    "render:diagrams:watch": "diagramkit render content/ --watch",
    "render:diagrams:check": "diagramkit validate content/ --recursive"
  },
  "dependencies": {
    "@pagesmith/site": "^0.9.9",
    "diagramkit": "^0.3.3",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plus": "^0.1.16",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=24"
  }
}
