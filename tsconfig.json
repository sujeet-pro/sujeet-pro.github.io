{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "@pagesmith/core",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "#lib/*": ["./lib/*"]
    }
  },
  "include": [
    "entry-server.tsx",
    "client.ts",
    "src/**/*.ts",
    "layouts/**/*.tsx",
    "runtime/**/*.ts",
    "lib/**/*.ts",
    "pagesmith.config.ts",
    "vite.config.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
