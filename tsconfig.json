{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@pagesmith/site",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "content.config.ts",
    "vite.config.ts",
    "lib/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "theme/**/*.ts",
    "theme/**/*.tsx"
  ]
}
